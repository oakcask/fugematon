{
  "name": "fugematon",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "scripts": {
    "build": "tsc -b && node workflow-scripts/web-playback-assets.mjs write-notice && pnpm --filter @fugematon/web build:bundle && node workflow-scripts/web-playback-assets.mjs verify",
    "clean": "pnpm clean:build",
    "clean:build": "tsc -b --clean && node scripts/clean-build-output.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "code-metrics": "node workflow-scripts/check-code-metrics.mjs",
    "test": "pnpm build && node scripts/run-node-tests.mjs",
    "test:review": "pnpm build && FUGEMATON_TEST_PROFILE=review node scripts/run-node-tests.mjs",
    "ui:inspect": "playwright test --project=chromium",
    "ui:inspect:listening": "playwright test --config playwright.listening.config.ts --project=chromium",
    "ui:inspect:prod": "playwright test --config playwright.prod.config.ts --project=chromium",
    "web:soundfont:prepare": "node workflow-scripts/web-playback-assets.mjs prepare-ubuntu-soundfont",
    "web:dev:soundfont": "pnpm web:soundfont:prepare && VITE_FUGEMATON_SOUNDFONT_URL=/soundfonts/MuseScore_General.sf3 pnpm build && VITE_FUGEMATON_SOUNDFONT_URL=/soundfonts/MuseScore_General.sf3 pnpm web:dev",
    "web:dev": "pnpm --filter @fugematon/web dev",
    "web:og-image": "pnpm --filter @fugematon/web og:image",
    "web:og-image:app-dist": "pnpm --filter @fugematon/web og:image:app-dist",
    "fugematon": "node packages/cli/dist/index.js",
    "samples:generate": "pnpm build && node packages/cli/dist/index.js midi --seed fugue-smoke --ticks 7680 --out samples/fugue-smoke-exposition.mid"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
