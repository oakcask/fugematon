{
  "name": "fugematon",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "scripts": {
    "build": "tsc -b && pnpm --filter @fugematon/web build:bundle",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm build && node --test packages/*/dist/**/*.test.js",
    "test:junit:check": "node scripts/check-node-test-junit-budget.mjs",
    "ui:inspect": "playwright test --project=chromium",
    "web:dev": "pnpm --filter @fugematon/web dev",
    "fugematon": "node packages/cli/dist/index.js",
    "samples:generate": "pnpm build && node packages/cli/dist/index.js midi --seed fugue-smoke --ticks 7680 --out samples/fugue-smoke-phase1.mid"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  }
}
