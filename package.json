{
  "name": "fugematon",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "type": "module",
  "scripts": {
    "build": "tsc -b && pnpm --filter @fugematon/web build:bundle",
    "clean": "pnpm clean:build",
    "clean:build": "tsc -b --clean && node scripts/clean-build-output.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "pnpm build && node --test packages/*/dist/**/*.test.js workflow-scripts/*.test.mjs scripts/*.test.mjs",
    "ui:inspect": "playwright test --project=chromium",
    "ui:inspect:prod": "playwright test --config playwright.prod.config.ts --project=chromium",
    "web:dev": "pnpm --filter @fugematon/web dev",
    "web:og-image": "pnpm --filter @fugematon/web og:image",
    "web:og-image:app-dist": "pnpm --filter @fugematon/web og:image:app-dist",
    "fugematon": "node packages/cli/dist/index.js",
    "samples:generate": "pnpm build && node packages/cli/dist/index.js midi --seed fugue-smoke --ticks 7680 --out samples/fugue-smoke-phase1.mid"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
