{
  "name": "@fugematon/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fugematon/core": "workspace:*",
    "@fugematon/performance": "workspace:*",
    "spessasynth_core": "4.3.7",
    "spessasynth_lib": "4.3.6"
  },
  "devDependencies": {
    "vite": "^8.0.13"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "og:image": "node scripts/render-og-image.mjs",
    "og:image:app-dist": "node scripts/render-og-image.mjs --app-dist",
    "build": "tsc -b && vite build",
    "build:bundle": "vite build",
    "test": "node --test dist/**/*.test.js"
  }
}
